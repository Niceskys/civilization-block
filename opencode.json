{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "wmb-executor",
  "share": "disabled",
  "autoupdate": false,
  "shell": "pwsh",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.env.example": "allow",
      "**/*.pem": "deny",
      "**/*.pfx": "deny",
      "**/*.p12": "deny",
      "**/*.key": "deny",
      "**/*secret*": "deny",
      "**/*token*": "deny",
      "**/*credential*": "deny",
      "**/auth.json": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",

      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git rev-parse*": "allow",
      "git ls-files*": "allow",
      "git grep*": "allow",
      "git branch --show-current*": "allow",
      "git branch --list*": "allow",

      "git add*": "deny",
      "git commit*": "deny",
      "git push*": "deny",
      "git pull*": "deny",
      "git fetch*": "deny",
      "git clone*": "deny",
      "git reset*": "deny",
      "git clean*": "deny",
      "git restore*": "deny",
      "git checkout*": "deny",
      "git switch*": "deny",
      "git stash*": "deny",
      "git merge*": "deny",
      "git rebase*": "deny",
      "git cherry-pick*": "deny",
      "git revert*": "deny",
      "git tag*": "deny",
      "git rm*": "deny",
      "git mv*": "deny",
      "git worktree*": "deny",
      "git submodule*": "deny",
      "git config*": "deny",

      "rm*": "deny",
      "del*": "deny",
      "erase*": "deny",
      "rmdir*": "deny",
      "Remove-Item*": "deny",
      "powershell *Remove-Item*": "deny",
      "pwsh *Remove-Item*": "deny",

      "curl*": "deny",
      "wget*": "deny",
      "Invoke-WebRequest*": "deny",
      "Invoke-RestMethod*": "deny",
      "iwr*": "deny",
      "irm*": "deny",

      "npm install*": "deny",
      "npm i *": "deny",
      "npm add*": "deny",
      "pnpm install*": "deny",
      "pnpm add*": "deny",
      "yarn install*": "deny",
      "yarn add*": "deny",
      "bun install*": "deny",
      "bun add*": "deny",
      "pip install*": "deny",
      "pip3 install*": "deny",
      "python -m pip install*": "deny",
      "py -m pip install*": "deny",
      "dotnet add*": "deny",
      "dotnet tool install*": "deny",
      "winget install*": "deny",
      "choco install*": "deny",
      "scoop install*": "deny",

      "setx*": "deny",
      "reg add*": "deny",
      "reg delete*": "deny",
      "format*": "deny",
      "diskpart*": "deny",
      "shutdown*": "deny",
      "restart-computer*": "deny"
    },
    "task": {
      "*": "deny",
      "wmb-reviewer": "ask"
    },
    "skill": {
      "*": "deny",
      "wmb-*": "allow"
    },
    "lsp": "ask",
    "question": "allow",
    "webfetch": "deny",
    "websearch": "deny",
    "external_directory": "deny",
    "doom_loop": "ask"
  }
}